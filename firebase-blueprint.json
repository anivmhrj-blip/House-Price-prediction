{
  "entities": {
    "Listing": {
      "title": "Listing",
      "description": "A property model representing active real estate listings.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the listing." },
        "address": { "type": "string", "description": "Street address of the property." },
        "neighborhood": { "type": "string", "description": "Local neighborhood Name." },
        "price": { "type": "number", "description": "Listing price of the property." },
        "beds": { "type": "number", "description": "Number of bedrooms." },
        "baths": { "type": "number", "description": "Number of bathrooms." },
        "sqft": { "type": "number", "description": "Square footage of the property." },
        "buildYear": { "type": "number", "description": "Year the property was built." },
        "propertyType": { "type": "string", "description": "Type of property (e.g., Single Family, Condo, Townhouse)." },
        "status": { "type": "string", "description": "Current status (e.g., Active, Sold, Pending)." },
        "imageUrl": { "type": "string", "description": "Image URL for the property." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["address", "neighborhood", "price", "beds", "baths", "sqft", "buildYear", "propertyType", "status", "createdAt"]
    },
    "SavedSearch": {
      "title": "SavedSearch",
      "description": "A user's saved search profile for notification alerts.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the saved search." },
        "userId": { "type": "string", "description": "User identifier who created the search." },
        "neighborhood": { "type": "string", "description": "Preferred neighborhood name." },
        "maxPrice": { "type": "number", "description": "Maximum budget." },
        "minBeds": { "type": "number", "description": "Minimum bedrooms count." },
        "propertyType": { "type": "string", "description": "Preferred housing property type." },
        "activeNotifications": { "type": "boolean", "description": "Whether listing notification alert is enabled." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "neighborhood", "maxPrice", "minBeds", "propertyType", "activeNotifications", "createdAt"]
    },
    "Valuation": {
      "title": "Valuation",
      "description": "A customized property valuation record generated by the prediction module.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the valuation." },
        "userId": { "type": "string", "description": "User identifier who requested valuation." },
        "neighborhood": { "type": "string", "description": "Neighborhood for valuation." },
        "beds": { "type": "number", "description": "Beds input for feature valuation." },
        "baths": { "type": "number", "description": "Baths input for feature valuation." },
        "sqft": { "type": "number", "description": "Sqft input for feature valuation." },
        "buildYear": { "type": "number", "description": "Year built input." },
        "propertyType": { "type": "string", "description": "Property type input." },
        "condition": { "type": "string", "description": "Property condition scale (e.g., Standard, Premium, Luxury)." },
        "predictedPrice": { "type": "number", "description": "Calculated valuation using real estate model." },
        "explanation": { "type": "string", "description": "Detailed AI market trend feedback." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Valuation calculation timestamp." }
      },
      "required": ["userId", "neighborhood", "beds", "baths", "sqft", "buildYear", "propertyType", "condition", "predictedPrice", "explanation", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "An alert or notification message delivered to a specific user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the notification." },
        "userId": { "type": "string", "description": "Owner of the notification." },
        "title": { "type": "string", "description": "Title of the alert." },
        "message": { "type": "string", "description": "Details about the notification." },
        "listingId": { "type": "string", "description": "Reference listing id that triggered notification." },
        "read": { "type": "boolean", "description": "Notification read state." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "MarketTrend": {
      "title": "MarketTrend",
      "description": "Aggregated historical sale trend details for a specific neighborhood.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier." },
        "neighborhood": { "type": "string", "description": "Neighborhood name." },
        "averagePricePerSqft": { "type": "number", "description": "Average sale or valuation price per square foot." },
        "growthRate": { "type": "number", "description": "Year-over-year value appreciate indicator index." },
        "monthlyHistory": { "type": "string", "description": "JSON string representing quarterly trend datapoints." }
      },
      "required": ["neighborhood", "averagePricePerSqft", "growthRate", "monthlyHistory"]
    }
  },
  "firestore": {
    "listings/{listingId}": {
      "schema": "Listing",
      "description": "Collection of all public housing listings."
    },
    "users/{userId}/savedSearches/{searchId}": {
      "schema": "SavedSearch",
      "description": "Collection of search profiles per user for notification matching."
    },
    "users/{userId}/valuations/{valuationId}": {
      "schema": "Valuation",
      "description": "Customized personal house features and calculated valuations."
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notification alerts."
    },
    "marketTrends/{trendId}": {
      "schema": "MarketTrend",
      "description": "Aggregated public data on historical price indices."
    }
  }
}
